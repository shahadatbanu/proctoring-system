# ── AI Service Environment Variables ──────────────────────────────────────────

HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=INFO

# ── Face Recognition ──────────────────────────────────────────────────────────
# Cosine distance threshold (lower = stricter). Recommended: 0.35–0.45
SIMILARITY_THRESHOLD=0.40
INSIGHTFACE_MODEL=buffalo_l

# ── Behaviour Analysis ────────────────────────────────────────────────────────
YAW_THRESHOLD=25
PITCH_THRESHOLD=20
ROLL_THRESHOLD=25
EAR_THRESHOLD=0.22

# ── Anti-Spoofing ─────────────────────────────────────────────────────────────
TEXTURE_VARIANCE_THRESHOLD=800
BLINK_WINDOW_FRAMES=30
BLINK_VARIANCE_THRESHOLD=5.0

# ── Face Tracking ─────────────────────────────────────────────────────────────
IOU_THRESHOLD=0.25
ABSENCE_TIMEOUT_SEC=5.0
